TELEMETRY_LISTENER_MQTT_HOST=mqtt-broker
TELEMETRY_LISTENER_MQTT_PORT=1883
TELEMETRY_LISTENER_MQTT_USERNAME=telemetry-listener
TELEMETRY_LISTENER_MQTT_PASSWORD=local-mqtt-password
TELEMETRY_LISTENER_MQTT_TOPICS=telemetry/#
TELEMETRY_LISTENER_CLIENT_ID=service-telemetry-listener-local
TELEMETRY_HUB_BASE_URL=http://telemetry-hub-api:8000
TELEMETRY_HUB_INGEST_PATH=/ingest/raw/
TELEMETRY_HUB_INGEST_KEY=local-telemetry-ingest-key
TELEMETRY_DEAD_LETTER_BASE_URL=http://telemetry-dead-letter-api:8000
TELEMETRY_DEAD_LETTER_INGEST_PATH=/ingest/
TELEMETRY_DEAD_LETTER_SOURCE_SERVICE=service-telemetry-listener
TELEMETRY_DEAD_LETTER_KEY_SERVICE_TELEMETRY_LISTENER=local-telemetry-dead-letter-listener-key
TELEMETRY_LISTENER_RETRY_COUNT=3
TELEMETRY_LISTENER_RETRY_BACKOFF_SECONDS=1.0
TELEMETRY_LISTENER_LOG_LEVEL=INFO
TELEMETRY_LISTENER_IDLE_SLEEP_SECONDS=5.0
